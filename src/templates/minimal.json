    "code": { "header": { "container": "display: none;", "dot": "display: none;", "colors": ["#52525b", "#52525b", "#52525b"] }, "block": "margin: 1.2em 0; padding: 14px; background: #fafafa; border: 1px solid #e4e4e7; color: #27272a;", "inline": "padding: 1px 4px; background: #f4f4f5; color: #3f3f46;" },
    "image": "border: 0; border-radius: 0;",
    "link": "color: #27272a; text-decoration: underline;",
    "emphasis": { "strong": "font-weight: 700; color: #18181b;", "em": "color: #52525b;", "del": "color: #a1a1aa;" },
    "table": { "container": "margin: 1.2em 0; border-collapse: collapse; border-top: 1px solid #71717a;", "header": "padding: 10px; color: #18181b; border-bottom: 1px solid #d4d4d8;", "cell": "padding: 10px; border-bottom: 1px solid #e4e4e7; color: #3f3f46;" },
    "hr": "margin: 28px 0; border: 0; border-top: 1px solid #d4d4d8;",
    "footnote": { "ref": "color: #52525b;", "backref": "color: #52525b;" }
  }
