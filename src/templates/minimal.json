  "styles": {
    "container": "background: #ffffff; padding: 0; color: #3f3f46;",
    "accentColor": "#3f3f46",
    "title": {
      "h1": { "base": "margin: 28px 0 20px; font-size: 1.8em; padding-bottom: 12px; border-bottom: 1px solid #a1a1aa;", "content": "font-weight: 700; color: #18181b;", "after": "" },
      "h2": { "base": "margin: 26px 0 12px; font-size: 1.38em;", "content": "font-weight: 700; color: #18181b;", "after": "" },
      "h3": { "base": "margin: 22px 0 10px; font-size: 1.15em;", "content": "font-weight: 700; color: #3f3f46;", "after": "" },
      "base": { "base": "margin: 18px 0 8px; font-size: 1em;", "content": "font-weight: 700; color: #52525b;", "after": "" }
    },
    "paragraph": "color: #3f3f46;",
    "list": { "container": "padding-left: 1.45em; color: #3f3f46;", "item": "color: #3f3f46;", "taskList": "list-style: none; padding-left: 0; color: #3f3f46;" },
