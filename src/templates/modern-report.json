{
  "id": "modern-report",
  "name": "报告与复盘",
  "description": "高对比但不过度装饰，适合周报、复盘、数据说明与阶段总结。",
  "source": "yh-mp-preview",
  "styles": {
    "container": "background: #ffffff; padding: 0; color: #30343b;",
    "accentColor": "#252b36",
    "title": {
      "h1": { "base": "margin: 28px 0 20px; font-size: 1.8em; padding-bottom: 12px; border-bottom: 3px solid #252b36;", "content": "font-weight: 700; color: #17191d;", "after": "" },
      "h2": { "base": "margin: 26px 0 12px; padding: 8px 12px; border-left: 4px solid #252b36; background: #f4f5f7; font-size: 1.35em;", "content": "font-weight: 700; color: #17191d;", "after": "" },
      "h3": { "base": "margin: 22px 0 10px; font-size: 1.15em;", "content": "font-weight: 700; color: #30343b;", "after": "" },
      "base": { "base": "margin: 18px 0 8px; font-size: 1em;", "content": "font-weight: 700; color: #30343b;", "after": "" }
    },
    "paragraph": "color: #30343b;",
    "list": { "container": "padding-left: 1.45em; color: #30343b;", "item": "color: #30343b;", "taskList": "list-style: none; padding-left: 0; color: #30343b;" },
    "quote": "margin: 1.1em 0; padding: 14px 16px; border-left: 4px solid #252b36; background: #f7f7f8; color: #4b5563;",
    "code": { "header": { "container": "margin-bottom: 6px; padding: 6px 10px; background: #e9ebef;", "dot": "display: none;", "colors": ["#252b36", "#252b36", "#252b36"] }, "block": "margin: 1.2em 0; padding: 14px; background: #f4f5f7; border: 1px solid #d9dde4; color: #252b36;", "inline": "padding: 1px 4px; background: #eceef1; color: #252b36;" },
    "image": "border: 1px solid #d9dde4; border-radius: 2px;",
    "link": "color: #252b36; text-decoration: underline;",
    "emphasis": { "strong": "font-weight: 700; color: #17191d;", "em": "color: #4b5563;", "del": "color: #9ca3af;" },
    "table": { "container": "margin: 1.2em 0; border-collapse: collapse; border-top: 2px solid #252b36;", "header": "padding: 10px; background: #252b36; color: #ffffff; border-bottom: 1px solid #252b36;", "cell": "padding: 10px; border-bottom: 1px solid #d9dde4; color: #30343b;" },
    "hr": "margin: 28px 0; border: 0; border-top: 1px solid #d9dde4;",
    "footnote": { "ref": "color: #252b36;", "backref": "color: #252b36;" }
  }
}
