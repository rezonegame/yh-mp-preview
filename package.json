{
	"name": "yh-mp-preview",
	"version": "3.5.0",
	"description": "一键将 Markdown 文档转换为微信公众号格式",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "node --test tests/*.test.mjs",
		"audit:themes": "node scripts/audit-themes.mjs --check",
		"audit:themes:write": "node scripts/audit-themes.mjs --write",
		"audit:core-themes": "node scripts/audit-core-theme-baseline.mjs --check",
		"audit:core-themes:write": "node scripts/audit-core-theme-baseline.mjs --write",
		"audit:wechat": "node scripts/audit-wechat-compatibility.mjs --check",
		"audit:wechat:write": "node scripts/audit-wechat-compatibility.mjs --write",
		"check:text": "node scripts/check-text-encoding.mjs",
		"sync-version": "node scripts/version-bump.mjs",
		"check:release": "node scripts/check-release.mjs",
		"verify": "npm run test && npm run check:text && npm run audit:themes && npm run audit:core-themes && npm run audit:wechat && npm run check:release",
		"version": "npm run sync-version"
	},
	"keywords": [
		"obsidian",
		"plugin"
	],
	"author": "yhwang",
	"license": "AGPL-3.0-or-later",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"builtin-modules": "3.3.0",
		"esbuild": "0.17.3",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "4.7.4"
	},
	"dependencies": {
		"html2canvas": "^1.4.1",
		"nanoid": "^5.1.5",
		"pangu": "^7.2.0"
	}
}
